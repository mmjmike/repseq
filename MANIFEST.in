include LICENSE
include README.md
include pyproject.toml
recursive-include repseq *.py *.json *.txt
recursive-include tests *.py
prune bin
prune mkdocs-env
prune mkdocs-venv
prune .idea
prune .vscode
prune src
exclude __init__.py
exclude pyvenv.cfg
exclude lib64
exclude dependencies.yml
exclude main_repseq.yml
exclude repseq/Untitled-2
exclude repseq/Untitled.ipynb
